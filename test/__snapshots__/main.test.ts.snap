            "HeatSheetAgentAlias",
            "AgentAliasId",
          ],
        },
      },
      "Type": "AWS::SSM::Parameter",
    },
    "AgentIdParam49DFB303": {
      "Properties": {
        "Description": "Bedrock Agent ID for the heat sheet extractor",
